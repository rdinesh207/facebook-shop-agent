# ─────────────────────────────────────────────
# Facebook / Meta Business
# ─────────────────────────────────────────────
# Long-lived user or system-user access token
FACEBOOK_ACCESS_TOKEN=

# Your Meta App credentials (from developers.facebook.com)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Facebook Page ID linked to your Shop
FACEBOOK_PAGE_ID=

# Meta Business Manager ID
FACEBOOK_BUSINESS_ID=

# (Optional) Pre-existing product catalog ID; leave blank to create one via API
FACEBOOK_CATALOG_ID=

# ─────────────────────────────────────────────
